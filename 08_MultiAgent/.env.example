# OpenAI
OPENAI_API_KEY=

# Tavily (선택 — 없으면 WebAgent 비활성화)
TAVILY_API_KEY=tvly-...

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# 인증 계정 (기본값: admin / ax2024)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ax2024

# 에이전트 설정
AGENT_MODEL=gpt-4o-mini   # RAG·웹·검증 에이전트
GEN_MODEL=gpt-4o          # 커리큘럼 생성 에이전트 (품질 우선)
VAL_MODEL=gpt-4o-mini
AGENT_MAX_RETRIES=3

# 파일 경로
OUTPUTS_DIR=outputs            # 커리큘럼 저장 디렉터리 (절대경로 또는 상대경로)

# CORS (프론트엔드 URL, 쉼표 구분)
CORS_ORIGINS=http://localhost:8501,https://your-app.streamlit.app
