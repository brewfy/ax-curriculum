# OpenAI
OPENAI_API_KEY=

# Tavily (선택 — 없으면 web_search 비활성화)
TAVILY_API_KEY=tvly-...

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRE_HOURS=24

# 인증 계정 (기본값: admin / ax2024)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ax2024

# Agent 설정
AGENT_MODEL=gpt-4o-mini
GEN_MODEL=gpt-4o-mini
AGENT_MAX_ITER=20
AGENT_MAX_RETRIES=3

# CORS (프론트엔드 URL, 쉼표 구분)
CORS_ORIGINS=http://localhost:8501,https://your-app.streamlit.app
